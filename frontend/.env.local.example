# Frontend environment — copy to .env.local and fill in.
# .env.local is gitignored; this file is the canonical reference.
#
# Variables prefixed with NEXT_PUBLIC_ are inlined into the client bundle —
# never put secrets here.

# Public origin of the deployed frontend (used for sitemap.xml, robots.txt,
# canonical/OG URLs). In production, set to your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Origin of the FastAPI backend.
# Local:      http://localhost:8000
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

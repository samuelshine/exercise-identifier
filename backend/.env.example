# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | production
DEBUG=false
API_VERSION=0.4.0
PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─── CORS / Trusted hosts ─────────────────────────────────────────────────────
# Comma-separated. In production set CORS_ORIGINS to your Vercel domain
# and TRUSTED_HOSTS to your API origin's host (no scheme, no path).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=*

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_SEARCH=20/minute
RATE_LIMIT_DEFAULT=120/minute

# ─── Request body limit ───────────────────────────────────────────────────────
MAX_REQUEST_BODY_BYTES=1048576    # 1 MiB

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/exercise_identifier
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_JUDGE_MODEL=gemma4:e4b
OLLAMA_JUDGE_TIMEOUT=8.0
OLLAMA_EMBED_TIMEOUT=5.0

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=exercise_descriptions

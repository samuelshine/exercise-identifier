# Copy to `.env` and fill in for your machine. `.env` is gitignored.

# SQLAlchemy async URL. For local Postgres with trust auth:
#   postgresql+asyncpg://<role>@localhost:5432/exercise_identifier
# For a password-protected DB:
#   postgresql+asyncpg://<role>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/exercise_identifier

DB_ECHO=false

VECTOR_DB_PROVIDER=pinecone
VECTOR_DB_INDEX=exercises
# VECTOR_DB_API_KEY=
